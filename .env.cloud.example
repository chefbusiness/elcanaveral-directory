# Plantilla de variables de entorno para correr elcanaveral.info en la nube
# (Abacus SuperComputer / Claude Code) o en cualquier máquina nueva.
#
# Uso:  cp .env.cloud.example .env   y rellena los valores reales.
# OJO:  .env está gitignored — NO se commitea. Los secretos NUNCA viajan por git.

# --- Sitio (públicas, no secretas) ---
PUBLIC_SITE_NAME="El Canaveral Info"
PUBLIC_SITE_URL=https://www.elcanaveral.info

# --- Google Places API (New) — fotos reales de negocios ---
# Dónde está el valor en tu Mac: ~/elcanaveral-directory/.env
# Origen: proyecto GCP gen-lang-client-0626625436. Tier gratuito ~10K text-searches/mes.
GOOGLE_PLACES_API_KEY=

# --- Apify — Google Maps scraper (enriquecer fichas + lead gen) ---
# Dónde está el valor en tu Mac: ~/chefbusiness-prospecting/.env  (variable APIFY_TOKEN)
# Reutilizable entre proyectos. También en apify.com -> Settings -> API & Integrations -> Personal API token.
APIFY_TOKEN=
