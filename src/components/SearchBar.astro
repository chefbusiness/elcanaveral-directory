---
// Busqueda client-side con Fuse.js
---

<div class="relative max-w-xl mx-auto" id="search-container">
  <div class="relative">
    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg">&#128269;</span>
    <input
      type="text"
      id="search-input"
      placeholder="Buscar negocios, servicios, restaurantes..."
      class="w-full bg-white border border-warm-200 rounded-xl pl-11 pr-5 py-4 text-base focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent shadow-sm placeholder:text-gray-400"
    />
  </div>
  <div
    id="search-results"
    class="absolute top-full left-0 right-0 bg-white border border-warm-200 rounded-xl mt-2 shadow-xl hidden z-50 max-h-80 overflow-y-auto"
  >
  </div>
</div>

<script>
  import Fuse from "fuse.js";

  const input = document.getElementById("search-input") as HTMLInputElement;
  const resultsDiv = document.getElementById("search-results")!;

  let fuse: Fuse<any> | null = null;

  input.addEventListener("focus", async () => {
    if (fuse) return;
    const res = await fetch("/data/negocios.json");
    const negocios = await res.json();
    fuse = new Fuse(negocios, {
      keys: ["name", "description", "categoryName", "zonaName", "tags", "servicios"],
      threshold: 0.3,
    });
  });

  input.addEventListener("input", () => {
    const query = input.value.trim();
    if (!query || !fuse) {
      resultsDiv.classList.add("hidden");
      return;
    }

    const results = fuse.search(query, { limit: 8 });
    if (results.length === 0) {
      resultsDiv.innerHTML = '<p class="p-4 text-gray-400 text-sm">No se encontraron resultados</p>';
    } else {
      resultsDiv.innerHTML = results
        .map(
          (r: any) => `
          <a href="/${r.item.category}/${r.item.slug}" class="flex items-center gap-3 px-4 py-3 hover:bg-warm-50 border-b border-warm-100 last:border-0 transition-colors">
            ${r.item.image ? `<img src="${r.item.image}" alt="" class="w-10 h-10 rounded-lg object-cover shrink-0"/>` : `<div class="w-10 h-10 rounded-lg bg-brand-50 flex items-center justify-center shrink-0 text-sm">${r.item.categoryName?.charAt(0) || '?'}</div>`}
            <div class="min-w-0">
              <p class="font-medium text-sm truncate">${r.item.name}</p>
              <p class="text-xs text-gray-400">${r.item.zonaName} · ${r.item.categoryName}</p>
            </div>
            ${r.item.rating ? `<span class="ml-auto text-xs font-medium text-yellow-600 shrink-0">★ ${r.item.rating}</span>` : ''}
          </a>
        `
        )
        .join("");
    }
    resultsDiv.classList.remove("hidden");
  });

  document.addEventListener("click", (e) => {
    if (!(e.target as HTMLElement).closest("#search-container")) {
      resultsDiv.classList.add("hidden");
    }
  });
</script>
