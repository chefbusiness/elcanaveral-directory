---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

// Mercadillos del barrio y alrededores (datos orientativos: confirmar fecha/horario antes de ir)
const mercadillos = [
  {
    name: "Mercadillo de El Cañaveral — «La Muestra»",
    dia: "Domingo (2º de cada mes)",
    horario: "10:00–18:00",
    lugar: "Avenida Provisional Gran Vía de Vicálvaro (junto a Los Ahijones), El Cañaveral",
    nota: "El mercadillo del propio barrio: alrededor de 40 puestos con productos gourmet, artesanía y segunda mano, música en vivo y actividades para toda la familia. Organizado por GESCOMER con la Junta Municipal de Vicálvaro.",
    maps: "Mercadillo La Muestra El Cañaveral Gran Vía de Vicálvaro",
    badge: "En el barrio",
  },
  {
    name: "Mercadillo de Vicálvaro",
    dia: "Jueves",
    horario: "9:00–14:00",
    lugar: "Calle Villablanca (Vicálvaro)",
    nota: "En el mismo distrito, a pocos minutos. Ropa, calzado, menaje del hogar, y puestos de fruta y verdura.",
    maps: "Mercadillo de Vicálvaro calle Villablanca Madrid",
    badge: null,
  },
  {
    name: "Mercadillo de Coslada",
    dia: "Viernes",
    horario: "9:00–14:00",
    lugar: "Recinto ferial de Coslada",
    nota: "Uno de los mercadillos más grandes de la zona: textil, calzado, hogar, alimentación y mucha variedad a buen precio.",
    maps: "Mercadillo de Coslada recinto ferial",
    badge: null,
  },
  {
    name: "Mercadillo de San Fernando de Henares",
    dia: "Viernes",
    horario: "8:00–14:30",
    lugar: "Aparcamiento junto a la estación de Metro Jarama",
    nota: "Mercadillo semanal junto al Metro Jarama, con gran variedad de productos frescos, ropa y artículos para el hogar a precios asequibles.",
    maps: "Mercadillo San Fernando de Henares Jarama",
    badge: null,
  },
];

const faq = [
  {
    q: "¿Hay mercadillo en El Cañaveral?",
    a: "Sí. El Cañaveral tiene su propio mercadillo, «La Muestra», el segundo domingo de cada mes (de 10:00 a 18:00), en la Avenida Provisional Gran Vía de Vicálvaro: unos 40 puestos de productos gourmet, artesanía y segunda mano, con música en vivo y actividades familiares. Entre semana, además, tienes los mercadillos de Vicálvaro (jueves), Coslada y San Fernando de Henares (viernes).",
  },
  {
    q: "¿Qué día es cada mercadillo cerca de El Cañaveral?",
    a: "El Cañaveral (La Muestra), el segundo domingo de cada mes de 10:00 a 18:00. Vicálvaro, los jueves de 9:00 a 14:00. Coslada, los viernes de 9:00 a 14:00 en el recinto ferial. San Fernando de Henares, los viernes de 8:00 a 14:30 junto al Metro Jarama. Las fechas y horarios pueden variar; conviene confirmarlos antes de ir.",
  },
  {
    q: "¿Y mercados cubiertos o mercados especiales?",
    a: "Vicálvaro cuenta con su mercado municipal (de abastos) para la compra del día a día. Además, a lo largo del año se montan mercados temáticos puntuales —medievales, castizos, navideños— que solemos recoger en la sección de fiestas y días especiales.",
  },
];

const base = "https://www.elcanaveral.info";
const maps = (q: string) => `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`;
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) };
const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [
  { "@type": "ListItem", position: 1, name: "Inicio", item: `${base}/` },
  { "@type": "ListItem", position: 2, name: "Mercados y mercadillos", item: `${base}/mercadillos/` },
] };
---

<BaseLayout
  title="Mercadillos y mercados cerca de El Cañaveral: días y horarios"
  description="Guía de mercadillos en El Cañaveral y alrededores: el mercadillo del barrio «La Muestra» (2º domingo de cada mes), más Vicálvaro (jueves), Coslada y San Fernando de Henares (viernes), con días, horarios y ubicación."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <article class="pt-24 pb-16 px-4">
    <div class="max-w-4xl mx-auto">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-brand-600">Inicio</a>
        <span class="mx-1.5 text-gray-300">/</span>
        <span class="text-gray-900">Mercados y mercadillos</span>
      </nav>

      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-brand-900 leading-tight">
          Mercadillos y mercados cerca de El Cañaveral
        </h1>
        <p class="text-gray-600 leading-relaxed mt-4 text-lg">
          ¿Buscas el mercadillo para comprar ropa, menaje, artesanía o fruta y verdura a buen precio? El Cañaveral
          tiene su propio mercadillo mensual, «La Muestra», y a pocos minutos hay varios más cada semana. Aquí los
          tienes con su <strong>día, horario y ubicación</strong>.
        </p>
      </header>

      <!-- Mercadillos semanales -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-brand-900 mb-1">🧺 Mercadillos del barrio y la zona</h2>
        <p class="text-gray-500 text-sm mb-5">El de El Cañaveral es mensual (2º domingo); los de alrededor, cada semana por la mañana.</p>
        <div class="grid sm:grid-cols-2 gap-5">
          {mercadillos.map((m) => (
            <div class="bg-white rounded-xl border border-warm-200 p-5 flex flex-col">
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-bold text-brand-900 leading-snug">{m.name}</h3>
                {m.badge && <span class="shrink-0 text-[11px] bg-accent-50 text-accent-700 px-2 py-0.5 rounded font-medium">{m.badge}</span>}
              </div>
              <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-sm">
                <span class="font-semibold text-brand-700">🗓️ {m.dia}</span>
                <span class="text-gray-600">🕘 {m.horario}</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">📍 {m.lugar}</p>
              <p class="text-gray-600 text-sm mt-3 leading-snug flex-1">{m.nota}</p>
              <a href={maps(m.maps)} target="_blank" rel="noopener" class="mt-3 text-sm font-medium text-brand-600 hover:text-brand-700">
                Ver en el mapa &rarr;
              </a>
            </div>
          ))}
        </div>
      </section>

      <!-- Mercados cubiertos / especiales -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-brand-900 mb-1">🏛️ Mercados municipales y especiales</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          <div class="bg-white rounded-xl border border-warm-200 p-5">
            <h3 class="font-bold text-brand-900">Mercado municipal de Vicálvaro</h3>
            <p class="text-gray-600 text-sm mt-2 leading-snug">El mercado de abastos del distrito para la compra del día a día: carnicería, pescadería, frutería y puestos tradicionales bajo techo.</p>
            <a href={maps("Mercado de Vicálvaro")} target="_blank" rel="noopener" class="mt-3 inline-block text-sm font-medium text-brand-600 hover:text-brand-700">Ver en el mapa &rarr;</a>
          </div>
          <div class="bg-white rounded-xl border border-warm-200 p-5">
            <h3 class="font-bold text-brand-900">Mercados temáticos (puntuales)</h3>
            <p class="text-gray-600 text-sm mt-2 leading-snug">A lo largo del año se montan mercados medievales, castizos y navideños en Vicálvaro, Coslada y San Fernando. Los recogemos en la sección de fiestas.</p>
            <a href="/fiestas" class="mt-3 inline-block text-sm font-medium text-brand-600 hover:text-brand-700">Ver fiestas y días especiales &rarr;</a>
          </div>
        </div>
      </section>

      <!-- Cross-link -->
      <div class="bg-brand-50 border border-brand-100 rounded-xl p-5 mb-12 text-sm text-gray-700">
        <span class="font-semibold text-brand-700">¿Buscas tiendas y grandes superficies?</span>
        Mira los <a href="/compras" class="text-brand-600 font-medium">outlets y centros comerciales cercanos</a> o
        los <a href="/directorio" class="text-brand-600 font-medium">comercios del propio barrio</a>.
      </div>

      <!-- FAQ -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-brand-900 mb-5">Preguntas frecuentes</h2>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="bg-white rounded-xl border border-warm-200 p-4 group">
              <summary class="font-semibold text-gray-800 cursor-pointer list-none flex items-center justify-between">
                {f.q}
                <span class="text-brand-400 group-open:rotate-180 transition-transform">&#9662;</span>
              </summary>
              <p class="text-gray-600 text-sm mt-3 leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <p class="text-xs text-gray-400 mt-8">
        Días y horarios orientativos; los mercadillos pueden cambiar de fecha o ubicación por festivos u
        organización municipal. Confirma con el ayuntamiento correspondiente antes de ir.
      </p>
    </div>
  </article>

  <Footer />
</BaseLayout>
