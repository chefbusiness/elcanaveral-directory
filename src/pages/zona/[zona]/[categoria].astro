---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import NegocioCard from "@/components/NegocioCard.astro";
import { generateZonaCategoriaPaths } from "@/lib/directory";
import { getListicleByCategory, getListicleByCategoryZona } from "@/lib/listicles";
import type { Negocio, Zona, Categoria } from "@/lib/directory";

export function getStaticPaths() {
  return generateZonaCategoriaPaths();
}

interface Props {
  zona: Zona;
  categoria: Categoria;
  negocios: Negocio[];
}

const { zona, categoria, negocios } = Astro.props;
// Prefiere la guia especifica de esta zona; si no, la general de la categoria.
const guia = getListicleByCategoryZona(categoria.slug, zona.slug) || getListicleByCategory(categoria.slug);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${categoria.name} en ${zona.name}`,
  description: `Directorio de ${categoria.name.toLowerCase()} en ${zona.name}.`,
  numberOfItems: negocios.length,
  itemListElement: negocios.slice(0, 20).map((n, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `https://www.elcanaveral.info/${n.category}/${n.slug}/`,
    name: n.name,
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: "https://www.elcanaveral.info/" },
    { "@type": "ListItem", position: 2, name: "Zonas", item: "https://www.elcanaveral.info/zonas/" },
    { "@type": "ListItem", position: 3, name: zona.name, item: `https://www.elcanaveral.info/zona/${zona.slug}/` },
    { "@type": "ListItem", position: 4, name: categoria.name, item: `https://www.elcanaveral.info/zona/${zona.slug}/${categoria.slug}/` },
  ],
};
---

<BaseLayout
  title={`${categoria.name} en ${zona.name}`}
  description={`${categoria.name} en ${zona.name}: direcciones, horarios y reseñas de los negocios de la zona. Encuentra ${categoria.name.toLowerCase()} cerca de ti en ${zona.name}.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <section class="pt-24 pb-16 px-4">
    <div class="max-w-6xl mx-auto">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-gray-700">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/zonas" class="hover:text-gray-700">Zonas</a>
        <span class="mx-2">/</span>
        <a href={`/zona/${zona.slug}`} class="hover:text-gray-700">{zona.name}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{categoria.name}</span>
      </nav>

      <div class="mb-8">
        <h1 class="text-3xl font-bold">
          {categoria.icon && <span class="mr-2">{categoria.icon}</span>}
          {categoria.name} en {zona.name}
        </h1>
        <p class="text-gray-600 mt-2">
          Directorio de {categoria.name.toLowerCase()} en {zona.name}.
          {categoria.description}
        </p>
        <p class="text-sm text-gray-400 mt-1">{negocios.length} negocios</p>
      </div>

      {guia && (
        <a
          href={`/blog/${guia.slug}`}
          class="block mb-8 bg-gradient-to-r from-brand-50 to-warm-100 border border-brand-100 rounded-xl p-4 sm:p-5 hover:border-brand-200 transition-colors group"
        >
          <div class="flex items-center justify-between gap-4">
            <div>
              <span class="text-xs font-semibold text-accent-600 uppercase tracking-wide">Guía del barrio</span>
              <p class="font-bold text-brand-900 group-hover:text-brand-600 leading-snug mt-0.5">{guia.h1}</p>
              <p class="text-sm text-gray-500 mt-0.5">Ranking por las valoraciones reales de Google</p>
            </div>
            <span class="shrink-0 text-sm font-semibold text-brand-600">Ver guía &rarr;</span>
          </div>
        </a>
      )}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {negocios.map((negocio) => (
          <NegocioCard negocio={negocio} />
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
