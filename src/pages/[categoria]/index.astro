---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import NegocioCard from "@/components/NegocioCard.astro";
import { generateCategoriaPaths, loadZonas, getNegociosByCategoriaYZona } from "@/lib/directory";
import { getListicleByCategory } from "@/lib/listicles";
import ZonaFilter from "@/components/ZonaFilter.astro";
import type { Negocio, Categoria } from "@/lib/directory";
import seoOverrides from "@/data/seo-overrides.json";

export function getStaticPaths() {
  return generateCategoriaPaths();
}

interface Props extends Categoria {
  negocios: Negocio[];
}

const { name, description, icon, negocios, count, slug } = Astro.props;
const zonas = loadZonas();
const zonasConNegocios = zonas
  .map((z) => ({
    ...z,
    count: getNegociosByCategoriaYZona(slug!, z.slug).length,
  }))
  .filter((z) => z.count > 0);

const guia = getListicleByCategory(slug!);
const seo = (seoOverrides.categorias as Record<string, any>)[slug!] || {};
const seoTitle = seo.title || `${name} en El Cañaveral y alrededores`;
const seoDesc = seo.description || description;
const seoH1 = seo.h1 || name;

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: seoH1,
  description: seoDesc,
  numberOfItems: negocios.length,
  itemListElement: negocios.map((n, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `https://www.elcanaveral.info/${n.category}/${n.slug}/`,
    name: n.name,
  })),
};
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <Header />

  <section class="pt-24 pb-16 px-4">
    <div class="max-w-6xl mx-auto">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-gray-700">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/directorio" class="hover:text-gray-700">Directorio</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{name}</span>
      </nav>

      <div class="mb-8">
        <h1 class="text-3xl font-bold">
          {icon && <span class="mr-2">{icon}</span>}{seoH1}
        </h1>
        <p class="text-gray-600 mt-2">{seoDesc}</p>
        <p class="text-sm text-gray-400 mt-1">{count} negocios</p>
      </div>

      {zonasConNegocios.length > 1 && (
        <ZonaFilter zonas={zonasConNegocios} total={negocios.length} />
      )}

      {guia && (
        <a
          href={`/blog/${guia.slug}`}
          class="block mb-8 bg-gradient-to-r from-brand-50 to-warm-100 border border-brand-100 rounded-xl p-4 sm:p-5 hover:border-brand-200 transition-colors group"
        >
          <div class="flex items-center justify-between gap-4">
            <div>
              <span class="text-xs font-semibold text-accent-600 uppercase tracking-wide">Guía del barrio</span>
              <p class="font-bold text-brand-900 group-hover:text-brand-600 leading-snug mt-0.5">{guia.h1}</p>
              <p class="text-sm text-gray-500 mt-0.5">Ranking por las valoraciones reales de Google</p>
            </div>
            <span class="shrink-0 text-sm font-semibold text-brand-600">Ver guía &rarr;</span>
          </div>
        </a>
      )}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {negocios.map((negocio) => (
          <NegocioCard negocio={negocio} />
        ))}
      </div>

      {negocios.length === 0 && (
        <p class="text-gray-500 text-center py-12">No hay negocios en esta categoria aun.</p>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>
