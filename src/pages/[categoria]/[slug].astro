---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import NegocioCard from "@/components/NegocioCard.astro";
import { generateNegocioPaths, generateLocalBusinessSchema, getNegociosByCategoria, getNegociosByZona } from "@/lib/directory";
import type { Negocio } from "@/lib/directory";

export function getStaticPaths() {
  return generateNegocioPaths();
}

const negocio = Astro.props as Negocio;
const schema = generateLocalBusinessSchema(negocio);
const servicios = (negocio.servicios as string[] | undefined) || [];
const destacados = (negocio.destacados as string[] | undefined) || [];
const especialidades = (negocio.especialidades as string[] | undefined) || [];
const tiposCocina = (negocio.tiposCocina as string[] | undefined) || [];
const redes = (negocio.redesSociales as Record<string, string> | undefined) || {};

// Negocios similares (misma categoria, excluyendo el actual)
const similares = getNegociosByCategoria(negocio.category)
  .filter((n) => n.slug !== negocio.slug)
  .slice(0, 3);

// Otros negocios en la zona (diferente categoria)
const otrosEnZona = getNegociosByZona(negocio.zona)
  .filter((n) => n.slug !== negocio.slug && n.category !== negocio.category)
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 4);
---

<BaseLayout title={`${negocio.name} — ${negocio.zonaName}`} description={negocio.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />

  <section class="pt-24 pb-8 px-4">
    <div class="max-w-5xl mx-auto">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-brand-600">Inicio</a>
        <span class="mx-1.5 text-gray-300">/</span>
        <a href={`/${negocio.category}`} class="hover:text-brand-600">{negocio.categoryName}</a>
        <span class="mx-1.5 text-gray-300">/</span>
        <a href={`/zona/${negocio.zona}`} class="hover:text-brand-600">{negocio.zonaName}</a>
        <span class="mx-1.5 text-gray-300">/</span>
        <span class="text-gray-900">{negocio.name}</span>
      </nav>

      <!-- Layout 2 columnas -->
      <div class="grid lg:grid-cols-3 gap-8">

        <!-- ===== COLUMNA PRINCIPAL ===== -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Hero image -->
          {negocio.image && (
            <img
              src={negocio.image}
              alt={`${negocio.name} en ${negocio.zonaName}`}
              class="w-full h-72 sm:h-80 object-cover rounded-xl"
            />
          )}

          <!-- Titulo + meta -->
          <div>
            <div class="flex items-start gap-3 mb-2">
              <h1 class="text-3xl font-bold text-brand-900">{negocio.name}</h1>
              {negocio.featured && (
                <span class="shrink-0 text-xs font-semibold bg-accent-500 text-white px-3 py-1 rounded-md mt-1.5">
                  Destacado
                </span>
              )}
            </div>

            <div class="flex flex-wrap items-center gap-3 mb-3">
              {negocio.rating && (
                <div class="flex items-center gap-1.5">
                  <div class="flex">
                    {[1,2,3,4,5].map((star) => (
                      <span class={`text-sm ${star <= Math.round(negocio.rating!) ? 'text-yellow-400' : 'text-gray-200'}`}>&#9733;</span>
                    ))}
                  </div>
                  <span class="font-semibold text-sm">{negocio.rating}</span>
                  {negocio.numReviews && (
                    <span class="text-gray-400 text-sm">({negocio.numReviews} resenas)</span>
                  )}
                </div>
              )}
              {negocio.precioRango && (
                <span class="text-sm text-gray-500 bg-warm-100 px-2 py-0.5 rounded font-medium">{negocio.precioRango}</span>
              )}
              <a href={`/${negocio.category}`} class="text-sm text-brand-600 hover:text-brand-700">{negocio.categoryName}</a>
              <span class="text-sm text-gray-400">{negocio.zonaName}</span>
            </div>

            <!-- Badges -->
            <div class="flex flex-wrap gap-2">
              {negocio.terraza && <span class="text-xs bg-green-50 text-green-700 px-2.5 py-1 rounded-full font-medium">Terraza</span>}
              {negocio.wifi && <span class="text-xs bg-blue-50 text-blue-700 px-2.5 py-1 rounded-full font-medium">WiFi</span>}
              {negocio.delivery && <span class="text-xs bg-orange-50 text-orange-700 px-2.5 py-1 rounded-full font-medium">Delivery</span>}
              {negocio.menuDelDia && <span class="text-xs bg-amber-50 text-amber-700 px-2.5 py-1 rounded-full font-medium">Menu del dia</span>}
              {negocio.aparcamiento && <span class="text-xs bg-purple-50 text-purple-700 px-2.5 py-1 rounded-full font-medium">Parking</span>}
              {negocio.accesibilidad && <span class="text-xs bg-teal-50 text-teal-700 px-2.5 py-1 rounded-full font-medium">Accesible</span>}
            </div>
          </div>

          <!-- Descripcion -->
          <div class="bg-white rounded-xl border border-warm-200 p-6">
            <h2 class="font-semibold text-lg mb-3">Sobre {negocio.name}</h2>
            <p class="text-gray-600 leading-relaxed">{negocio.description}</p>
          </div>

          <!-- Info especifica por tipo -->
          {(negocio.edades || negocio.plazas || negocio.tipoGestion) && (
            <div class="bg-blue-50 rounded-xl p-6 border border-blue-100">
              <h2 class="font-semibold text-lg mb-4">Informacion del centro</h2>
              <div class="grid sm:grid-cols-3 gap-4">
                {negocio.edades && (
                  <div class="bg-white rounded-lg p-3 text-center">
                    <span class="text-xs text-gray-400 uppercase tracking-wider block">Edades</span>
                    <p class="font-bold text-lg text-brand-600 mt-1">{negocio.edades}</p>
                  </div>
                )}
                {negocio.plazas && (
                  <div class="bg-white rounded-lg p-3 text-center">
                    <span class="text-xs text-gray-400 uppercase tracking-wider block">Plazas</span>
                    <p class="font-bold text-lg text-brand-600 mt-1">{negocio.plazas}</p>
                  </div>
                )}
                {negocio.tipoGestion && (
                  <div class="bg-white rounded-lg p-3 text-center">
                    <span class="text-xs text-gray-400 uppercase tracking-wider block">Gestion</span>
                    <p class="font-bold text-lg text-brand-600 mt-1 capitalize">{negocio.tipoGestion}</p>
                  </div>
                )}
              </div>
            </div>
          )}

          {tiposCocina.length > 0 && (
            <div class="bg-white rounded-xl border border-warm-200 p-6">
              <h2 class="font-semibold text-lg mb-3">Tipo de cocina</h2>
              <div class="flex flex-wrap gap-2">
                {tiposCocina.map((tipo) => (
                  <span class="text-sm bg-accent-50 text-accent-700 px-3 py-1.5 rounded-lg font-medium capitalize">{tipo}</span>
                ))}
              </div>
            </div>
          )}

          {especialidades.length > 0 && (
            <div class="bg-white rounded-xl border border-warm-200 p-6">
              <h2 class="font-semibold text-lg mb-3">Especialidades</h2>
              <div class="grid sm:grid-cols-2 gap-2">
                {especialidades.map((esp) => (
                  <div class="flex items-center gap-2 text-sm text-gray-700 py-1">
                    <span class="w-5 h-5 bg-brand-50 text-brand-600 rounded-full flex items-center justify-center text-xs font-bold">&#10003;</span>
                    <span class="capitalize">{esp}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Servicios -->
          {servicios.length > 0 && (
            <div class="bg-white rounded-xl border border-warm-200 p-6">
              <h2 class="font-semibold text-lg mb-3">Servicios</h2>
              <div class="grid sm:grid-cols-2 gap-2">
                {servicios.map((servicio) => (
                  <div class="flex items-center gap-2 text-sm text-gray-700 py-1">
                    <span class="w-5 h-5 bg-brand-50 text-brand-600 rounded-full flex items-center justify-center text-xs font-bold">&#10003;</span>
                    <span>{servicio}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Destacados -->
          {destacados.length > 0 && (
            <div class="bg-gradient-to-br from-brand-50 to-brand-100 rounded-xl p-6 border border-brand-200">
              <h2 class="font-semibold text-lg mb-3">Por que elegir {negocio.name}</h2>
              <ul class="space-y-2.5">
                {destacados.map((d) => (
                  <li class="flex items-start gap-3 text-sm text-gray-700">
                    <span class="text-accent-500 mt-0.5 text-base">&#9733;</span>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Mapa grande (principal) -->
          {negocio.address && (
            <div class="bg-white rounded-xl border border-warm-200 overflow-hidden">
              <div class="p-4 border-b border-warm-200">
                <h2 class="font-semibold text-lg">Como llegar</h2>
                <p class="text-sm text-gray-500 mt-0.5">{negocio.address}</p>
              </div>
              <iframe
                src={`https://www.google.com/maps?q=${encodeURIComponent(negocio.address)}&output=embed`}
                width="100%"
                height="350"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Mapa de ${negocio.name}`}
              ></iframe>
              <div class="p-3 text-right">
                <a
                  href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(negocio.address)}`}
                  target="_blank"
                  rel="noopener"
                  class="text-sm font-medium text-brand-600 hover:text-brand-700"
                >
                  Abrir en Google Maps &rarr;
                </a>
              </div>
            </div>
          )}

          <!-- Tags -->
          {negocio.tags && negocio.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {negocio.tags.map((tag) => (
                <span class="text-xs bg-warm-100 text-gray-500 px-3 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          )}
        </div>

        <!-- ===== SIDEBAR ===== -->
        <div class="lg:col-span-1">
          <div class="space-y-5 lg:sticky lg:top-20 lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto lg:pb-4 scrollbar-hide">

          <!-- Card contacto -->
          <div class="bg-white rounded-xl border border-warm-200 p-5">
            <h2 class="font-semibold text-lg mb-4">Contacto</h2>
            <div class="space-y-3">
              {negocio.address && (
                <div class="flex items-start gap-3">
                  <span class="text-gray-400 text-sm mt-0.5 shrink-0">&#128205;</span>
                  <span class="text-sm">{negocio.address}</span>
                </div>
              )}
              <div class="flex items-center gap-3">
                <span class="text-gray-400 text-sm shrink-0">&#128204;</span>
                <a href={`/zona/${negocio.zona}`} class="text-sm text-brand-600 hover:text-brand-700">{negocio.zonaName}</a>
              </div>
              {negocio.phone && (
                <div class="flex items-center gap-3">
                  <span class="text-gray-400 text-sm shrink-0">&#128222;</span>
                  <a href={`tel:${negocio.phone}`} class="text-sm text-brand-600 hover:text-brand-700 font-medium">{negocio.phone}</a>
                </div>
              )}
              {negocio.email && (
                <div class="flex items-center gap-3">
                  <span class="text-gray-400 text-sm shrink-0">&#9993;</span>
                  <a href={`mailto:${negocio.email}`} class="text-sm text-brand-600 hover:text-brand-700 break-all">{negocio.email}</a>
                </div>
              )}
              {negocio.website && (
                <div class="flex items-center gap-3">
                  <span class="text-gray-400 text-sm shrink-0">&#127760;</span>
                  <a href={negocio.website} target="_blank" rel="noopener" class="text-sm text-brand-600 hover:text-brand-700 break-all">{negocio.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a>
                </div>
              )}
              {negocio.horario && (
                <div class="flex items-start gap-3">
                  <span class="text-gray-400 text-sm mt-0.5 shrink-0">&#128336;</span>
                  <span class="text-sm whitespace-pre-line">{negocio.horario}</span>
                </div>
              )}
            </div>

            {(redes.instagram || redes.facebook) && (
              <div class="border-t border-warm-200 mt-4 pt-3 flex gap-3">
                {redes.instagram && (
                  <a href={`https://instagram.com/${redes.instagram.replace('@', '')}`} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-brand-600">Instagram</a>
                )}
                {redes.facebook && (
                  <a href={redes.facebook} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-brand-600">Facebook</a>
                )}
              </div>
            )}

            <div class="mt-4 space-y-2">
              {negocio.phone && (
                <a href={`tel:${negocio.phone}`} class="block w-full text-center bg-brand-600 text-white py-2.5 rounded-lg font-medium hover:bg-brand-700 transition-colors">
                  Llamar ahora
                </a>
              )}
              {negocio.website && (
                <a href={negocio.website} target="_blank" rel="noopener" class="block w-full text-center bg-white text-brand-600 border border-brand-200 py-2.5 rounded-lg font-medium hover:bg-brand-50 transition-colors">
                  Visitar web
                </a>
              )}
              {negocio.address && (
                <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(negocio.address)}`} target="_blank" rel="noopener" class="block w-full text-center bg-white text-gray-600 border border-warm-200 py-2.5 rounded-lg font-medium hover:bg-warm-50 transition-colors">
                  Como llegar
                </a>
              )}
            </div>
          </div>

          <!-- Mapa compacto sidebar -->
          {negocio.address && (
            <div class="rounded-xl overflow-hidden border border-warm-200">
              <iframe
                src={`https://www.google.com/maps?q=${encodeURIComponent(negocio.address)}&output=embed`}
                width="100%"
                height="200"
                style="border:0;"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Ubicacion de ${negocio.name}`}
              ></iframe>
            </div>
          )}

          <!-- Banner LocalSEOAds -->
          <div class="bg-brand-900 rounded-xl p-5 text-center text-white">
            <p class="text-sm font-medium mb-1">Tu negocio aqui</p>
            <p class="text-xs text-brand-200 mb-3">Destaca en el directorio y atrae mas clientes de tu barrio</p>
            <a
              href="https://localseoads.com"
              target="_blank"
              rel="noopener"
              class="inline-block text-sm font-semibold bg-accent-500 text-white px-4 py-2 rounded-lg hover:bg-accent-600 transition-colors"
            >
              Posicionar mi negocio
            </a>
          </div>
          </div><!-- close sticky wrapper -->
        </div>
      </div>
    </div>
  </section>

  <!-- Negocios similares (misma categoria) -->
  {similares.length > 0 && (
    <section class="py-12 px-4 bg-white border-t border-warm-200">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-end justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-brand-900">Negocios similares</h2>
            <p class="text-sm text-gray-500 mt-0.5">Otros {negocio.categoryName.toLowerCase()} en la zona</p>
          </div>
          <a href={`/${negocio.category}`} class="text-sm font-medium text-brand-600 hover:text-brand-700">Ver todos &rarr;</a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {similares.map((n) => (
            <NegocioCard negocio={n} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Otros negocios en la zona -->
  {otrosEnZona.length > 0 && (
    <section class="py-12 px-4 border-t border-warm-200">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-end justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold text-brand-900">Descubre en {negocio.zonaName}</h2>
            <p class="text-sm text-gray-500 mt-0.5">Otros negocios cerca de ti</p>
          </div>
          <a href={`/zona/${negocio.zona}`} class="text-sm font-medium text-brand-600 hover:text-brand-700">Ver zona &rarr;</a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {otrosEnZona.map((n) => (
            <NegocioCard negocio={n} />
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>
