---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { generateNegocioPaths, generateLocalBusinessSchema } from "@/lib/directory";
import type { Negocio } from "@/lib/directory";

export function getStaticPaths() {
  return generateNegocioPaths();
}

const negocio = Astro.props as Negocio;
const schema = generateLocalBusinessSchema(negocio);
---

<BaseLayout title={negocio.name} description={negocio.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />

  <section class="pt-24 pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-gray-700">Inicio</a>
        <span class="mx-2">/</span>
        <a href={`/${negocio.category}`} class="hover:text-gray-700">{negocio.categoryName}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{negocio.name}</span>
      </nav>

      {negocio.image && (
        <img
          src={negocio.image}
          alt={negocio.name}
          class="w-full h-64 object-cover rounded-xl mb-8"
        />
      )}

      <div class="flex items-start gap-3 mb-4">
        <h1 class="text-3xl font-bold">{negocio.name}</h1>
        {negocio.featured && (
          <span class="shrink-0 text-xs font-medium bg-brand-50 text-brand-700 px-3 py-1 rounded-full mt-2">
            Destacado
          </span>
        )}
      </div>

      {negocio.rating && (
        <div class="flex items-center gap-2 mb-4">
          <span class="text-yellow-500 text-lg">&#9733;</span>
          <span class="font-semibold text-lg">{negocio.rating}</span>
          {negocio.numReviews && (
            <span class="text-gray-400">({negocio.numReviews} resenas)</span>
          )}
        </div>
      )}

      <p class="text-lg text-gray-600 mb-8">{negocio.description}</p>

      <!-- Datos de contacto -->
      <div class="bg-gray-50 rounded-xl p-6 space-y-3 mb-8">
        <h2 class="font-semibold text-lg mb-3">Informacion de contacto</h2>
        {negocio.address && (
          <div class="flex gap-3">
            <span class="text-gray-400 w-24 shrink-0 text-sm">Direccion</span>
            <span>{negocio.address}</span>
          </div>
        )}
        <div class="flex gap-3">
          <span class="text-gray-400 w-24 shrink-0 text-sm">Zona</span>
          <a href={`/zona/${negocio.zona}`} class="text-brand-600 hover:text-brand-700">{negocio.zonaName}</a>
        </div>
        {negocio.phone && (
          <div class="flex gap-3">
            <span class="text-gray-400 w-24 shrink-0 text-sm">Telefono</span>
            <a href={`tel:${negocio.phone}`} class="text-brand-600 hover:text-brand-700">{negocio.phone}</a>
          </div>
        )}
        {negocio.email && (
          <div class="flex gap-3">
            <span class="text-gray-400 w-24 shrink-0 text-sm">Email</span>
            <a href={`mailto:${negocio.email}`} class="text-brand-600 hover:text-brand-700">{negocio.email}</a>
          </div>
        )}
        {negocio.website && (
          <div class="flex gap-3">
            <span class="text-gray-400 w-24 shrink-0 text-sm">Web</span>
            <a href={negocio.website} target="_blank" rel="noopener" class="text-brand-600 hover:text-brand-700">{negocio.website}</a>
          </div>
        )}
        {negocio.horario && (
          <div class="flex gap-3">
            <span class="text-gray-400 w-24 shrink-0 text-sm">Horario</span>
            <span>{negocio.horario}</span>
          </div>
        )}
        {negocio.address && (
          <div class="pt-2">
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(negocio.address)}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-sm text-brand-600 hover:text-brand-700"
            >
              Ver en Google Maps &rarr;
            </a>
          </div>
        )}
      </div>

      {negocio.tags && negocio.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {negocio.tags.map((tag) => (
            <span class="text-sm bg-gray-100 text-gray-600 px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      )}

      <!-- Mapa -->
      {negocio.address && (
        <div class="mb-8">
          <h2 class="font-semibold text-lg mb-3">Ubicacion</h2>
          <div class="rounded-xl overflow-hidden border border-gray-200">
            <iframe
              src={`https://www.google.com/maps?q=${encodeURIComponent(negocio.address)}&output=embed`}
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Mapa de ${negocio.name}`}
            ></iframe>
          </div>
          <div class="flex items-center justify-between mt-2">
            <p class="text-sm text-gray-500">{negocio.address}</p>
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(negocio.address)}`}
              target="_blank"
              rel="noopener"
              class="text-sm text-brand-600 hover:text-brand-700"
            >
              Obtener direcciones &rarr;
            </a>
          </div>
        </div>
      )}

      <!-- Banner LocalSEOAds -->
      <div class="bg-accent-50 border border-blue-100 rounded-xl p-6 text-center">
        <p class="text-sm text-gray-600 mb-2">Quieres destacar tu negocio en este directorio?</p>
        <a
          href="https://localseoads.com"
          target="_blank"
          rel="noopener"
          class="text-sm font-medium text-accent-600 hover:text-accent-700"
        >
          Conoce nuestros servicios de posicionamiento local &rarr;
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
