---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SearchBar from "@/components/SearchBar.astro";
import NegocioCard from "@/components/NegocioCard.astro";
import { loadCategorias, loadZonas, getFeaturedNegocios, loadNegocios } from "@/lib/directory";

const categorias = loadCategorias();
const zonas = loadZonas();
const featured = getFeaturedNegocios(6);
const totalNegocios = loadNegocios().length;
---

<BaseLayout
  title="Directorio de Negocios Locales"
  description="El directorio mas completo de negocios, comercios y servicios en El Canaveral, Vicalvaro, Coslada y San Fernando de Henares. Encuentra lo que necesitas cerca de casa."
>
  <Header />

  <!-- Hero -->
  <section class="pt-24 pb-20 px-4 bg-gradient-to-b from-brand-50 via-white to-warm-50 relative">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;><g fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;><g fill=&quot;%23000&quot;><path d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/></g></g></svg>');"></div>
    <div class="max-w-4xl mx-auto text-center relative">
      <div class="inline-flex items-center gap-2 bg-brand-100 text-brand-700 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
        <span class="w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
        {totalNegocios} negocios registrados
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-brand-900 mb-5 leading-[1.1]">
        Tu barrio, tus negocios.<br/>
        <span class="text-brand-600">Todo en un solo lugar.</span>
      </h1>
      <p class="text-lg text-gray-500 mb-10 max-w-2xl mx-auto">
        Encuentra comercios, restaurantes y servicios en El Canaveral, Vicalvaro, Coslada y San Fernando de Henares.
      </p>
      <SearchBar />
    </div>
  </section>

  <!-- Stats rapidos -->
  <section class="px-4 -mt-8 relative z-10">
    <div class="max-w-4xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-3">
      {zonas.map((zona) => (
        <a
          href={`/zona/${zona.slug}`}
          class="bg-white rounded-xl border border-warm-200 p-4 text-center hover:shadow-md hover:border-brand-200 transition-all"
        >
          <p class="text-2xl font-bold text-brand-600">{zona.count}</p>
          <p class="text-sm text-gray-500 mt-0.5">{zona.name}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Categorias -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold text-brand-900">Explora por categoria</h2>
          <p class="text-gray-500 mt-1">Encuentra exactamente lo que necesitas</p>
        </div>
        <a href="/directorio" class="text-sm font-medium text-brand-600 hover:text-brand-700">Ver todo &rarr;</a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {categorias.map((cat) => (
          <a
            href={`/${cat.slug}`}
            class={`flex items-center gap-3 p-4 rounded-xl border transition-all ${(cat.count ?? 0) > 0 ? 'bg-white border-warm-200 hover:shadow-md hover:border-brand-200' : 'bg-warm-50 border-warm-100 opacity-50'}`}
          >
            {cat.icon && <span class="text-2xl">{cat.icon}</span>}
            <div>
              <h3 class="font-semibold text-sm">{cat.name}</h3>
              <span class="text-xs text-gray-400">{cat.count} negocios</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Destacados -->
  {featured.length > 0 && (
    <section class="py-16 px-4 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-2xl font-bold text-brand-900">Negocios destacados</h2>
            <p class="text-gray-500 mt-1">Los mejor valorados por los vecinos</p>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featured.map((negocio) => (
            <NegocioCard negocio={negocio} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Registro -->
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="bg-brand-900 rounded-2xl p-10 sm:p-14 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,<svg width=&quot;20&quot; height=&quot;20&quot; viewBox=&quot;0 0 20 20&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;><circle cx=&quot;1&quot; cy=&quot;1&quot; r=&quot;1&quot; fill=&quot;white&quot;/></svg>');"></div>
        <div class="relative">
          <h2 class="text-3xl font-bold text-white mb-4">Tienes un negocio en El Canaveral?</h2>
          <p class="text-brand-200 mb-8 max-w-xl mx-auto">
            Aparece en el directorio local mas completo de la zona.
            Miles de vecinos ya lo usan para encontrar negocios como el tuyo.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="/alta"
              class="inline-block bg-accent-500 text-white font-semibold px-6 py-3 rounded-lg hover:bg-accent-600 transition-colors shadow-lg"
            >
              Registrar mi negocio gratis
            </a>
            <a
              href="https://localseoads.com"
              target="_blank"
              rel="noopener"
              class="inline-block bg-white/10 text-white font-medium px-6 py-3 rounded-lg hover:bg-white/20 transition-colors border border-white/20"
            >
              Posicionar mi negocio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
