---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const submitted = Astro.url.searchParams.get("ok") === "1";

const beneficios = [
  {
    titulo: "Exclusividad real en tu categoría",
    texto: "Solo 1 sponsor por categoría. Si firmas inmobiliarias, ningún competidor puede aparecer destacado en esa sección. Bloqueas el slot durante toda la duración del acuerdo.",
  },
  {
    titulo: "Presencia site-wide en todas las páginas",
    texto: "Banner rotativo en home, fichas de negocios, listados por zona y categoría, blog y hub social del barrio. Cada visita al directorio cuenta.",
  },
  {
    titulo: "Tu ficha como referencia editorial",
    texto: "Badge dorado de patrocinador oficial, tarjeta destacada en sidebar de toda tu categoría, CTA directo a tu web desde cada ficha relacionada.",
  },
  {
    titulo: "Newsletter y redes co-brandeadas",
    texto: "Mención en el boletín mensual a vecinos suscritos al directorio, presencia en el hub social del barrio y posibilidad de co-creación de contenido (entrevista, reportaje).",
  },
  {
    titulo: "Reportes de tráfico transparentes",
    texto: "Informe mensual con páginas vistas, visitas únicas, clics a tu ficha y rendimiento de tus banners. Sin medias tintas: ves lo que está funcionando.",
  },
  {
    titulo: "Activación rápida tras la firma",
    texto: "Aplicamos featured + badge + banners en menos de 24 horas tras la firma. Cero fricción técnica: tú nos pasas creatividades, nosotros las publicamos.",
  },
];

const faqs = [
  {
    q: "¿Quién es buen candidato a sponsor exclusivo?",
    a: "Negocios o marcas que quieren dominar su categoría en el barrio: una inmobiliaria que quiere ser LA referencia para vender pisos en El Cañaveral; un grupo dental que quiere capturar al barrio; un seguro o gestor que quiere posicionarse como el de cabecera. Cuanto más concentrado quieras ser, más sentido tiene el sponsor.",
  },
  {
    q: "¿Cuánto tráfico tiene el directorio?",
    a: "El directorio se lanzó en abril de 2026 y está en fase de crecimiento orgánico vía SEO local. Cada candidato a sponsor recibe los datos reales de tráfico actuales y el plan de crecimiento estimado antes de firmar. La propuesta se construye sobre datos verificables, no sobre proyecciones infladas.",
  },
  {
    q: "¿Por qué 800 €/mes y no 200 €?",
    a: "Porque es exclusividad. Bloqueas la categoría completa durante 12 meses: el resto de competidores no pueden aparecer destacados, ni con banner, ni con featured. Para una inmobiliaria del barrio que cierra una venta de 5K-10K€ en comisiones, el ROI es directo. Para un negocio con tickets más pequeños, probablemente tiene más sentido el plan Destacado (49 €/mes).",
  },
  {
    q: "¿Qué pasa si la categoría que me interesa ya tiene sponsor?",
    a: "Te lo decimos al recibir tu solicitud. Mientras el slot esté ocupado, te ofrecemos el plan Destacado (49 €/mes), que también pone tu ficha en lo más alto pero sin exclusividad. En cuanto el slot del sponsor quede libre, tienes prioridad para entrar.",
  },
  {
    q: "¿Cuál es la duración mínima?",
    a: "12 meses, con bonificación a partir del mes 3 (gratis los primeros 60 días para activar el contenido y ver primeros resultados). Después, renovación anual a precio fijo o renegociación según volumen del directorio.",
  },
  {
    q: "¿Puedo ver una propuesta antes de comprometerme?",
    a: "Sí. Tras tu solicitud te enviamos una propuesta personalizada en formato PDF con: tráfico actual, fórmulas de activación, calendario, métricas clave y desglose de cuota. Sin compromiso. La firma se hace solo cuando ambas partes estamos alineadas.",
  },
];
---

<BaseLayout
  title="Sponsor exclusivo del directorio"
  description="Patrocinio integral por categoría desde 800 €/mes: presencia site-wide, ficha premium, newsletter y reportes transparentes. Solo 1 sponsor por categoría."
>
  <Header />

  <!-- Hero -->
  <section class="pt-24 pb-16 px-4 bg-gradient-to-b from-brand-900 to-brand-800 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block bg-accent-500 text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider mb-5">
        Solo 1 sponsor por categoría
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-5 tracking-tight">
        Domina tu categoría en el barrio
      </h1>
      <p class="text-lg sm:text-xl text-brand-100 max-w-2xl mx-auto leading-relaxed mb-8">
        Patrocinio exclusivo desde <strong class="text-white">800 €/mes</strong>. Tu negocio como
        referencia editorial del directorio. Tu competencia, fuera del slot premium durante 12 meses.
      </p>
      <a href="#solicitar" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-semibold px-8 py-3.5 rounded-lg transition-colors">
        Solicitar propuesta personalizada
      </a>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="px-4 py-16">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 text-center mb-3">Qué incluye el sponsor exclusivo</h2>
      <p class="text-center text-warm-600 mb-12 max-w-2xl mx-auto">
        Más que un banner. Una alianza editorial entre tu marca y el directorio del barrio.
      </p>
      <div class="grid md:grid-cols-2 gap-5">
        {beneficios.map((b) => (
          <div class="bg-white border border-warm-200 rounded-xl p-6">
            <h3 class="font-bold text-brand-900 mb-2 text-lg">{b.titulo}</h3>
            <p class="text-warm-700 leading-relaxed">{b.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ROI / Por qué exclusividad -->
  <section class="px-4 py-16 bg-warm-50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 mb-6 text-center">Por qué exclusividad</h2>
      <div class="space-y-5 text-warm-800 text-lg leading-relaxed">
        <p>
          Un banner sin exclusividad compite con los del resto. Un sponsor exclusivo
          <strong class="text-brand-900">bloquea la categoría</strong>: ningún otro competidor del barrio
          aparece destacado, en ningún sitio, durante 12 meses.
        </p>
        <p>
          Para sectores con ticket medio alto — inmobiliario, dental, seguros, asesoría fiscal,
          guardería privada, fisioterapia premium — la diferencia entre aparecer "destacado entre 8"
          y "ser el único" cambia el cálculo del ROI.
        </p>
        <p>
          Si una venta media de tu negocio cubre 1-3 cuotas mensuales de sponsorship, y este canal
          te da una sola venta extra al mes, te paga el año.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-4 py-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 text-center mb-10">Preguntas frecuentes</h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group bg-white border border-warm-200 rounded-lg overflow-hidden">
            <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer font-semibold text-brand-900 hover:bg-warm-50">
              <span>{f.q}</span>
              <span class="text-accent-500 text-xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-4 pb-4 text-warm-700 leading-relaxed">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Form -->
  <section id="solicitar" class="px-4 py-16 bg-warm-50 scroll-mt-24">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 text-center mb-3">Solicita propuesta personalizada</h2>
      <p class="text-center text-warm-600 mb-10">
        Te enviamos una propuesta en PDF con tráfico, plan de activación y cuota cerrada en menos de 72 horas. Sin compromiso.
      </p>

      {submitted ? (
        <div class="bg-white border-2 border-accent-500 rounded-2xl p-8 text-center">
          <div class="text-5xl mb-4">✓</div>
          <h3 class="text-2xl font-bold text-brand-900 mb-2">Solicitud recibida</h3>
          <p class="text-warm-700 mb-6">
            Revisamos tu candidatura y te enviamos la propuesta personalizada por email
            en menos de 72 horas. Si necesitas urgencia, escribe a
            <a href="mailto:local@elcanaveral.info" class="text-brand-700 underline">local@elcanaveral.info</a>.
          </p>
          <a href="/" class="inline-block bg-brand-900 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-800 transition-colors">
            Volver al directorio
          </a>
        </div>
      ) : (
        <div class="bg-white border border-warm-200 rounded-2xl p-6 sm:p-8 shadow-sm">
          <form
            name="sponsor"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/sponsor?ok=1#solicitar"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="sponsor" />
            <p class="hidden"><label>No rellenar: <input name="bot-field" /></label></p>

            <div>
              <label for="empresa" class="block text-sm font-semibold text-brand-900 mb-1">Empresa o marca *</label>
              <input id="empresa" name="empresa" type="text" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
            </div>

            <div>
              <label for="categoria" class="block text-sm font-semibold text-brand-900 mb-1">Categoría que quieres patrocinar *</label>
              <select id="categoria" name="categoria" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg bg-white focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100">
                <option value="">Selecciona</option>
                <option>Inmobiliarias</option>
                <option>Salud y bienestar (dental, fisio, ópticas...)</option>
                <option>Educación (guarderías, academias...)</option>
                <option>Restaurantes</option>
                <option>Servicios profesionales (asesoría, abogados...)</option>
                <option>Hogar y reformas</option>
                <option>Automoción</option>
                <option>Belleza</option>
                <option>Deporte</option>
                <option>Supermercados / alimentación</option>
                <option>Otra (especifica en comentarios)</option>
              </select>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="contacto" class="block text-sm font-semibold text-brand-900 mb-1">Tu nombre *</label>
                <input id="contacto" name="contacto" type="text" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
              </div>
              <div>
                <label for="cargo" class="block text-sm font-semibold text-brand-900 mb-1">Cargo</label>
                <input id="cargo" name="cargo" type="text" placeholder="Ej: Director comercial" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-sm font-semibold text-brand-900 mb-1">Email *</label>
                <input id="email" name="email" type="email" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
              </div>
              <div>
                <label for="telefono" class="block text-sm font-semibold text-brand-900 mb-1">Teléfono</label>
                <input id="telefono" name="telefono" type="tel" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
              </div>
            </div>

            <div>
              <label for="web" class="block text-sm font-semibold text-brand-900 mb-1">Web de tu empresa</label>
              <input id="web" name="web" type="url" placeholder="https://..." class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
            </div>

            <div>
              <label for="presupuesto" class="block text-sm font-semibold text-brand-900 mb-1">Rango de presupuesto mensual aproximado</label>
              <select id="presupuesto" name="presupuesto" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg bg-white focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100">
                <option>800 € - 1.200 €</option>
                <option>1.200 € - 2.000 €</option>
                <option>Más de 2.000 €</option>
                <option>Aún no lo tengo claro</option>
              </select>
            </div>

            <div>
              <label for="comentarios" class="block text-sm font-semibold text-brand-900 mb-1">Cuéntanos tu objetivo</label>
              <textarea id="comentarios" name="comentarios" rows="4" placeholder="¿Qué quieres conseguir con el sponsorship? ¿Tienes deadline? ¿Hay competencia que te preocupa especialmente?" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100"></textarea>
            </div>

            <label class="flex items-start gap-3 text-sm text-warm-700">
              <input type="checkbox" name="acepto-rgpd" required class="mt-1" />
              <span>
                Acepto la <a href="/privacidad" class="text-brand-700 underline">política de privacidad</a> y los <a href="/terminos" class="text-brand-700 underline">términos y condiciones</a>.
              </span>
            </label>

            <button type="submit" class="w-full bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3 rounded-lg transition-colors">
              Solicitar propuesta →
            </button>

            <p class="text-xs text-warm-500 text-center">
              Respuesta en menos de 72 horas · sin compromiso
            </p>
          </form>
        </div>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>
