---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import espaciosData from "@/data/espacios.json";

const espacios = espaciosData as any[];

const TIPOS = [
  { id: "infantil", label: "Parques infantiles", icon: "🛝", desc: "Zonas de juegos para los más pequeños" },
  { id: "canino", label: "Parques para perros", icon: "🐶", desc: "Áreas caninas (pipican) para soltar a tu perro" },
  { id: "parque", label: "Parques y zonas verdes", icon: "🌳", desc: "Espacios verdes para pasear y descansar" },
  { id: "deporte", label: "Pistas y áreas deportivas", icon: "🏀", desc: "Deporte al aire libre" },
  { id: "senderismo", label: "Caminerías y zonas de paseo", icon: "🥾", desc: "Rutas y entornos naturales cercanos" },
];

const grupos = TIPOS.map((t) => ({
  ...t,
  items: espacios.filter((e) => e.tipo === t.id),
})).filter((g) => g.items.length > 0);

const total = espacios.length;
const mapsLink = (e: any) =>
  e.placeId
    ? `https://www.google.com/maps/place/?q=place_id:${e.placeId}`
    : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent((e.name || "") + " El Cañaveral")}`;

const base = "https://www.elcanaveral.info";
const faq = [
  { q: "¿Cuántos parques infantiles hay en El Cañaveral?", a: "El barrio cuenta con varias áreas de juegos infantiles repartidas por sus calles, muchas renovadas recientemente por el ayuntamiento. En esta guía recogemos las que aparecen en Google Maps con su ubicación." },
  { q: "¿Hay parque para perros (pipican) en El Cañaveral?", a: "Sí, hay áreas caninas donde soltar al perro, por ejemplo junto a la Avenida de Miguel Delibes. Las listamos en la sección 'Parques para perros'." },
  { q: "¿Dónde hacer deporte al aire libre en El Cañaveral?", a: "Hay pistas deportivas y un área de entrenamiento físico (calistenia) al aire libre, además de las caminerías y zonas de paseo del entorno del barrio." },
];
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${base}/` },
    { "@type": "ListItem", position: 2, name: "Parques y espacios públicos", item: `${base}/espacios-publicos/` },
  ],
};
---

<BaseLayout
  title="Parques y espacios públicos de El Cañaveral"
  description="Guía de parques infantiles, parques para perros (pipican), zonas verdes, pistas deportivas y caminerías de El Cañaveral (Madrid), con su ubicación en el mapa."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <article class="pt-24 pb-16 px-4">
    <div class="max-w-4xl mx-auto">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-brand-600">Inicio</a>
        <span class="mx-1.5 text-gray-300">/</span>
        <span class="text-gray-900">Parques y espacios públicos</span>
      </nav>

      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-brand-900 leading-tight">
          Parques y espacios públicos de El Cañaveral
        </h1>
        <p class="text-gray-600 leading-relaxed mt-4 text-lg">
          El Cañaveral es un barrio nuevo y muy familiar, con parques infantiles, zonas caninas, áreas
          verdes y espacios deportivos —muchos recién remodelados por el ayuntamiento— que atraen también
          a vecinos de las zonas de alrededor. Aquí tienes {total} de esos espacios con su ubicación en el mapa.
        </p>
      </header>

      <!-- Índice por tipo -->
      <div class="flex flex-wrap gap-2 mb-10">
        {grupos.map((g) => (
          <a href={`#${g.id}`} class="text-sm font-medium bg-white border border-warm-200 px-3 py-1.5 rounded-full hover:border-brand-300">
            {g.icon} {g.label} ({g.items.length})
          </a>
        ))}
      </div>

      {grupos.map((g) => (
        <section id={g.id} class="mb-12 scroll-mt-24">
          <h2 class="text-2xl font-bold text-brand-900 flex items-center gap-2">{g.icon} {g.label}</h2>
          <p class="text-gray-500 text-sm mt-1 mb-5">{g.desc}</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {g.items.map((e) => (
              <div class="bg-white rounded-xl border border-warm-200 overflow-hidden flex flex-col">
                {e.image ? (
                  <img src={e.image} alt={e.name} class="w-full h-36 object-cover" loading="lazy" />
                ) : (
                  <div class="w-full h-36 bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center text-4xl">{g.icon}</div>
                )}
                <div class="p-4 flex flex-col flex-1">
                  <h3 class="font-semibold text-brand-900 leading-snug">{e.name}</h3>
                  {e.address && <p class="text-xs text-gray-500 mt-1 line-clamp-2">{e.address}</p>}
                  {e.rating && (
                    <p class="text-xs text-gray-400 mt-1">{e.rating}★ ({e.numReviews})</p>
                  )}
                  <a href={mapsLink(e)} target="_blank" rel="noopener" class="mt-3 text-sm font-medium text-brand-600 hover:text-brand-700">
                    Cómo llegar &rarr;
                  </a>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}

      <!-- Mapa general -->
      <div class="bg-white rounded-xl border border-warm-200 overflow-hidden mb-10">
        <div class="p-4 border-b border-warm-200">
          <h2 class="font-semibold text-lg">El Cañaveral en el mapa</h2>
        </div>
        <div
          data-maps-embed
          data-src="https://www.google.com/maps?q=El%20Ca%C3%B1averal,%20Madrid&output=embed"
          data-title="Mapa de El Cañaveral"
          class="h-[350px] bg-warm-100 flex flex-col items-center justify-center text-center px-6"
        >
          <p class="text-sm text-gray-500 mb-3">El mapa usa cookies de Google Maps. Púlsalo para cargarlo.</p>
          <button data-maps-load type="button" class="text-sm font-semibold bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors">Ver mapa</button>
        </div>
      </div>

      <!-- FAQ -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-brand-900 mb-5">Preguntas frecuentes</h2>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="bg-white rounded-xl border border-warm-200 p-4 group">
              <summary class="font-semibold text-gray-800 cursor-pointer list-none flex items-center justify-between">
                {f.q}
                <span class="text-brand-400 group-open:rotate-180 transition-transform">&#9662;</span>
              </summary>
              <p class="text-gray-600 text-sm mt-3 leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <p class="text-xs text-gray-400">
        Listado elaborado a partir de Google Maps. ¿Falta un parque o espacio del barrio, o hay algún dato que corregir?
        Escríbenos a <a href="mailto:local@elcanaveral.info" class="text-brand-600">local@elcanaveral.info</a> y lo añadimos.
      </p>
    </div>
  </article>

  <Footer />
</BaseLayout>
