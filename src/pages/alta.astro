---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const submitted = Astro.url.searchParams.get("ok") === "1";
---

<BaseLayout
  title="Registra tu negocio gratis"
  description="Añade tu negocio al directorio de El Cañaveral, Vicálvaro y alrededores. Listado básico gratuito en menos de 48 horas."
>
  <Header />

  <section class="pt-24 pb-12 px-4 bg-gradient-to-b from-warm-50 to-white">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-brand-900 mb-4 tracking-tight">
        Registra tu negocio
      </h1>
      <p class="text-lg text-warm-700 max-w-2xl mx-auto leading-relaxed">
        Añade tu negocio al directorio del barrio sin coste. Lo publicamos en menos de 48 horas si los datos son verificables.
      </p>
      <p class="text-sm text-warm-500 mt-3">
        ¿Buscas más visibilidad? Mira los <a href="/planes" class="text-brand-700 underline">planes de pago</a>.
      </p>
    </div>
  </section>

  {submitted ? (
    <section class="px-4 pb-20">
      <div class="max-w-2xl mx-auto bg-white border-2 border-accent-500 rounded-2xl p-8 text-center">
        <div class="text-5xl mb-4">✓</div>
        <h2 class="text-2xl font-bold text-brand-900 mb-2">¡Recibido!</h2>
        <p class="text-warm-700 mb-6">
          Hemos recibido los datos de tu negocio. Lo revisamos y te confirmamos por email en menos de 48 horas.
        </p>
        <a href="/" class="inline-block bg-brand-900 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-800 transition-colors">
          Volver al directorio
        </a>
      </div>
    </section>
  ) : (
    <section class="px-4 pb-20">
      <div class="max-w-2xl mx-auto bg-white border border-warm-200 rounded-2xl p-6 sm:p-8 shadow-sm">
        <form
          name="alta-negocio"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/alta?ok=1"
          class="space-y-5"
        >
          <input type="hidden" name="form-name" value="alta-negocio" />
          <p class="hidden"><label>No rellenar: <input name="bot-field" /></label></p>

          <div>
            <label for="negocio" class="block text-sm font-semibold text-brand-900 mb-1">Nombre del negocio *</label>
            <input id="negocio" name="negocio" type="text" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
          </div>

          <div>
            <label for="categoria" class="block text-sm font-semibold text-brand-900 mb-1">Categoría *</label>
            <select id="categoria" name="categoria" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg bg-white focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100">
              <option value="">Selecciona una categoría</option>
              <option>Restaurantes</option>
              <option>Cafeterías</option>
              <option>Panaderías</option>
              <option>Supermercados</option>
              <option>Fruterías</option>
              <option>Tiendas de alimentación</option>
              <option>Salud y bienestar</option>
              <option>Belleza</option>
              <option>Deporte</option>
              <option>Educación</option>
              <option>Hogar</option>
              <option>Mascotas</option>
              <option>Moda</option>
              <option>Automoción</option>
              <option>Servicios profesionales</option>
              <option>Inmobiliarias</option>
              <option>Otra</option>
            </select>
          </div>

          <div>
            <label for="direccion" class="block text-sm font-semibold text-brand-900 mb-1">Dirección completa *</label>
            <input id="direccion" name="direccion" type="text" required placeholder="Ej: Calle Victoria Kent 8, 28052 Madrid" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="zona" class="block text-sm font-semibold text-brand-900 mb-1">Zona *</label>
              <select id="zona" name="zona" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg bg-white focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100">
                <option value="">Selecciona</option>
                <option>El Cañaveral</option>
                <option>Vicálvaro</option>
                <option>Coslada</option>
                <option>San Fernando de Henares</option>
              </select>
            </div>
            <div>
              <label for="telefono" class="block text-sm font-semibold text-brand-900 mb-1">Teléfono</label>
              <input id="telefono" name="telefono" type="tel" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="web" class="block text-sm font-semibold text-brand-900 mb-1">Web del negocio</label>
              <input id="web" name="web" type="url" placeholder="https://..." class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
            </div>
            <div>
              <label for="instagram" class="block text-sm font-semibold text-brand-900 mb-1">Instagram</label>
              <input id="instagram" name="instagram" type="text" placeholder="@usuario" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
            </div>
          </div>

          <div>
            <label for="descripcion" class="block text-sm font-semibold text-brand-900 mb-1">Descripción breve</label>
            <textarea id="descripcion" name="descripcion" rows="3" placeholder="Qué hace tu negocio en 1-3 frases" class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100"></textarea>
          </div>

          <hr class="border-warm-200" />

          <div>
            <label for="email" class="block text-sm font-semibold text-brand-900 mb-1">Tu email de contacto *</label>
            <input id="email" name="email" type="email" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
            <p class="text-xs text-warm-500 mt-1">Solo lo usamos para confirmar la publicación de la ficha.</p>
          </div>

          <div>
            <label for="rol" class="block text-sm font-semibold text-brand-900 mb-1">¿Eres...? *</label>
            <select id="rol" name="rol" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg bg-white focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100">
              <option value="">Selecciona</option>
              <option>El propietario del negocio</option>
              <option>Empleado/encargado autorizado</option>
              <option>Vecino del barrio recomendando un negocio</option>
            </select>
          </div>

          <label class="flex items-start gap-3 text-sm text-warm-700">
            <input type="checkbox" name="acepto-rgpd" required class="mt-1" />
            <span>
              Acepto la <a href="/privacidad" class="text-brand-700 underline">política de privacidad</a> y los <a href="/terminos" class="text-brand-700 underline">términos y condiciones</a>.
            </span>
          </label>

          <button type="submit" class="w-full bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3 rounded-lg transition-colors">
            Enviar solicitud →
          </button>

          <p class="text-xs text-warm-500 text-center">
            Listado gratuito · respuesta en menos de 48 horas
          </p>
        </form>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>
