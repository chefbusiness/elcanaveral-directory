---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const submitted = Astro.url.searchParams.get("ok") === "1";
---

<BaseLayout
  title="Contacto"
  description="Contacta con el directorio elcanaveral.info: dudas sobre fichas, planes de visibilidad, sponsorships o errores en el directorio."
>
  <Header />

  <section class="pt-24 pb-12 px-4 bg-gradient-to-b from-warm-50 to-white">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-brand-900 mb-4 tracking-tight">
        Contacto
      </h1>
      <p class="text-lg text-warm-700 max-w-2xl mx-auto leading-relaxed">
        Dudas, errores en una ficha, recomendaciones, prensa o cualquier otro tema. Te respondemos en menos de 48 horas.
      </p>
    </div>
  </section>

  <section class="px-4 pb-20">
    <div class="max-w-2xl mx-auto">
      <div class="grid sm:grid-cols-3 gap-3 mb-8 text-sm">
        <a href="/alta" class="bg-white border border-warm-200 rounded-lg p-4 hover:border-brand-600 transition-colors">
          <div class="font-semibold text-brand-900 mb-1">¿Quieres registrar tu negocio?</div>
          <div class="text-warm-600">Listado básico gratis →</div>
        </a>
        <a href="/anunciate" class="bg-white border border-warm-200 rounded-lg p-4 hover:border-brand-600 transition-colors">
          <div class="font-semibold text-brand-900 mb-1">¿Quieres más visibilidad?</div>
          <div class="text-warm-600">Verificado o Destacado →</div>
        </a>
        <a href="/sponsor" class="bg-white border border-warm-200 rounded-lg p-4 hover:border-brand-600 transition-colors">
          <div class="font-semibold text-brand-900 mb-1">Sponsor exclusivo</div>
          <div class="text-warm-600">Patrocinio categorial →</div>
        </a>
      </div>

      {submitted ? (
        <div class="bg-white border-2 border-accent-500 rounded-2xl p-8 text-center">
          <div class="text-5xl mb-4">✓</div>
          <h2 class="text-2xl font-bold text-brand-900 mb-2">Mensaje recibido</h2>
          <p class="text-warm-700 mb-6">Te respondemos por email en menos de 48 horas.</p>
          <a href="/" class="inline-block bg-brand-900 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-800 transition-colors">
            Volver al directorio
          </a>
        </div>
      ) : (
        <div class="bg-white border border-warm-200 rounded-2xl p-6 sm:p-8 shadow-sm">
          <form
            name="contacto"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/contacto?ok=1"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="contacto" />
            <p class="hidden"><label>No rellenar: <input name="bot-field" /></label></p>

            <div>
              <label for="motivo" class="block text-sm font-semibold text-brand-900 mb-1">Motivo *</label>
              <select id="motivo" name="motivo" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg bg-white focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100">
                <option value="">Selecciona</option>
                <option>Error o cambio en una ficha existente</option>
                <option>Recomendación de un negocio nuevo</option>
                <option>Pregunta sobre planes de pago</option>
                <option>Sponsor exclusivo / propuesta comercial</option>
                <option>Prensa o medios</option>
                <option>Otra cosa</option>
              </select>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="nombre" class="block text-sm font-semibold text-brand-900 mb-1">Nombre *</label>
                <input id="nombre" name="nombre" type="text" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-brand-900 mb-1">Email *</label>
                <input id="email" name="email" type="email" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
              </div>
            </div>

            <div>
              <label for="ficha-url" class="block text-sm font-semibold text-brand-900 mb-1">URL de la ficha (si aplica)</label>
              <input id="ficha-url" name="ficha-url" type="url" placeholder="https://www.elcanaveral.info/..." class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
            </div>

            <div>
              <label for="mensaje" class="block text-sm font-semibold text-brand-900 mb-1">Mensaje *</label>
              <textarea id="mensaje" name="mensaje" rows="5" required class="w-full px-4 py-2.5 border border-warm-300 rounded-lg focus:outline-none focus:border-brand-600 focus:ring-2 focus:ring-brand-100"></textarea>
            </div>

            <label class="flex items-start gap-3 text-sm text-warm-700">
              <input type="checkbox" name="acepto-rgpd" required class="mt-1" />
              <span>
                Acepto la <a href="/privacidad" class="text-brand-700 underline">política de privacidad</a>.
              </span>
            </label>

            <button type="submit" class="w-full bg-accent-500 hover:bg-accent-600 text-white font-semibold py-3 rounded-lg transition-colors">
              Enviar mensaje →
            </button>
          </form>
        </div>
      )}

      <p class="text-center text-sm text-warm-600 mt-6">
        También puedes escribirnos directamente a
        <a href="mailto:local@elcanaveral.info" class="text-brand-700 font-semibold underline">local@elcanaveral.info</a>
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>
