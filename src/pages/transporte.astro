---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const buses = [
  {
    n: "159",
    tipo: "Urbano (EMT) · día",
    desc: "Conecta El Cañaveral con el Metro L2 (estación Alsacia) y, a su paso por Vicálvaro, con la estación de Cercanías y el Metro L9.",
    color: "bg-[#1877F2]",
  },
  {
    n: "E5",
    tipo: "Exprés (EMT) · día",
    desc: "Línea exprés Manuel Becerra ↔ El Cañaveral (Blas de Lezo). La forma más rápida de llegar al centro de Madrid, en unos 30-40 minutos.",
    color: "bg-accent-600",
  },
  {
    n: "290",
    tipo: "Interurbano · día",
    desc: "Une El Cañaveral con Coslada Central (Metro L7 y Cercanías) y con el centro comercial Plenilunio.",
    color: "bg-brand-600",
  },
  {
    n: "N6",
    tipo: "Búho (EMT) · noche",
    desc: "Autobús nocturno que conecta Plaza de Cibeles con El Cañaveral. La EMT prolongó la N6 hasta el barrio, así que de madrugada también tienes vuelta a casa.",
    color: "bg-brand-900",
  },
];

const faq = [
  {
    q: "¿Hay metro en El Cañaveral?",
    a: "Todavía no hay estación de Metro dentro del barrio. Las más cercanas son Coslada Central (L7) y Vicálvaro (L9). El Consorcio de Transportes tiene previsto un apeadero de Cercanías en El Cañaveral.",
  },
  {
    q: "¿Qué autobuses llegan a El Cañaveral?",
    a: "De día, las líneas 159 (conecta con Metro L2 y, vía Vicálvaro, con L9 y Cercanías), la E5 exprés (al centro de Madrid) y la 290 (a Coslada y Plenilunio). De noche, el búho N6 hasta Plaza de Cibeles.",
  },
  {
    q: "¿Cómo llego de El Cañaveral al centro de Madrid?",
    a: "La opción más rápida es la línea exprés E5 hasta Manuel Becerra (unos 30-40 minutos). También puedes coger la 159 y enlazar con el Metro L2.",
  },
  {
    q: "¿Hay autobús nocturno (búho)?",
    a: "Sí. El búho N6 conecta El Cañaveral con Plaza de Cibeles durante la madrugada, con más frecuencia los fines de semana y vísperas de festivo.",
  },
  {
    q: "¿Cuál es la estación de Cercanías más cercana?",
    a: "La estación de Vicálvaro (líneas C2 y C7), a unos 17-19 minutos andando. Coslada Central también tiene Cercanías y está conectada por la línea 290.",
  },
];

const base = "https://www.elcanaveral.info";
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${base}/` },
    { "@type": "ListItem", position: 2, name: "Cómo llegar y transporte", item: `${base}/transporte/` },
  ],
};
---

<BaseLayout
  title="Cómo llegar a El Cañaveral: autobuses, Cercanías y transporte"
  description="Cómo llegar a El Cañaveral (Madrid): líneas de autobús (159, E5 exprés, 290), búho nocturno N6, Cercanías, Metro cercano, taxi y VTC. Conexiones con Madrid, Coslada, Vicálvaro y San Fernando de Henares."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <article class="pt-24 pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <nav class="text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-brand-600">Inicio</a>
        <span class="mx-1.5 text-gray-300">/</span>
        <span class="text-gray-900">Cómo llegar y transporte</span>
      </nav>

      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-brand-900 leading-tight">
          Cómo llegar a El Cañaveral: transporte y conexiones
        </h1>
        <p class="text-gray-600 leading-relaxed mt-4 text-lg">
          El Cañaveral es un barrio joven y en plena expansión al este de Madrid, junto a Vicálvaro,
          Coslada y San Fernando de Henares. Aún no tiene Metro propio, pero está bien conectado por
          autobús —incluido servicio nocturno— y por las Cercanías de las localidades vecinas. Aquí tienes
          todas las opciones para moverte de día y de noche.
        </p>
      </header>

      <!-- Autobuses -->
      <h2 class="text-2xl font-bold text-brand-900 mb-4 flex items-center gap-2">🚌 Autobuses</h2>
      <div class="space-y-3 mb-10">
        {buses.map((b) => (
          <div class="bg-white rounded-xl border border-warm-200 p-4 sm:p-5 flex items-start gap-4">
            <span class={`shrink-0 w-14 h-14 rounded-lg ${b.color} text-white flex items-center justify-center font-bold text-lg`}>
              {b.n}
            </span>
            <div>
              <p class="text-xs font-semibold text-accent-600 uppercase tracking-wide">{b.tipo}</p>
              <p class="text-gray-700 mt-1 leading-snug">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Cercanías + Metro -->
      <div class="grid sm:grid-cols-2 gap-4 mb-10">
        <div class="bg-white rounded-xl border border-warm-200 p-5">
          <h2 class="text-lg font-bold text-brand-900 mb-2 flex items-center gap-2">🚆 Cercanías</h2>
          <p class="text-gray-700 text-sm leading-relaxed">
            Líneas <strong>C2 y C7</strong>. La estación más cercana es <strong>Vicálvaro</strong>
            (~17-19 min andando). <strong>Coslada Central</strong> también tiene Cercanías y conecta por la línea 290.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-200 p-5">
          <h2 class="text-lg font-bold text-brand-900 mb-2 flex items-center gap-2">🚇 Metro</h2>
          <p class="text-gray-700 text-sm leading-relaxed">
            Sin estación en el barrio (de momento). Las más cercanas: <strong>Coslada Central (L7)</strong> y
            <strong>Vicálvaro (L9)</strong>. Hay un <strong>apeadero de Cercanías en El Cañaveral</strong> previsto por el Consorcio.
          </p>
        </div>
      </div>

      <!-- Nocturno destacado -->
      <div class="bg-gradient-to-r from-brand-900 to-brand-700 rounded-2xl p-6 mb-10 text-white">
        <h2 class="text-xl font-bold flex items-center gap-2">🌙 Transporte de noche</h2>
        <p class="text-brand-100 mt-2 text-sm sm:text-base leading-relaxed">
          El búho <strong>N6</strong> conecta El Cañaveral con <strong>Plaza de Cibeles</strong> durante la
          madrugada, con más frecuencia los viernes, sábados y vísperas de festivo. Es tu mejor opción para
          volver a casa después de una noche por el centro.
        </p>
      </div>

      <!-- Taxi / VTC / coche -->
      <div class="grid sm:grid-cols-2 gap-4 mb-10">
        <div class="bg-white rounded-xl border border-warm-200 p-5">
          <h2 class="text-lg font-bold text-brand-900 mb-2 flex items-center gap-2">🚕 Taxi y VTC</h2>
          <p class="text-gray-700 text-sm leading-relaxed">
            Operan en la zona el radio-taxi de Coslada y San Fernando de Henares y los servicios VTC
            (<strong>Uber, Cabify, Bolt</strong>), útiles cuando no hay autobús o para ir cargado.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-warm-200 p-5">
          <h2 class="text-lg font-bold text-brand-900 mb-2 flex items-center gap-2">🚗 En coche</h2>
          <p class="text-gray-700 text-sm leading-relaxed">
            Buen acceso por la <strong>A-3</strong>, la <strong>M-45</strong> y la <strong>M-50</strong>.
            Aún hay aparcamiento en superficie en buena parte del barrio.
          </p>
        </div>
      </div>

      <!-- Planifica tu ruta -->
      <div class="bg-warm-100 rounded-xl p-5 mb-10">
        <h2 class="text-lg font-bold text-brand-900 mb-2">🗺️ Planifica tu ruta (horarios en vivo)</h2>
        <p class="text-gray-600 text-sm mb-3">
          Los horarios y frecuencias cambian. Consulta siempre la información actualizada en las fuentes oficiales:
        </p>
        <div class="flex flex-wrap gap-2">
          <a href="https://www.crtm.es" target="_blank" rel="noopener" class="text-sm font-medium bg-white border border-warm-200 px-3 py-1.5 rounded-lg hover:border-brand-300">CRTM (Consorcio)</a>
          <a href="https://www.emtmadrid.es" target="_blank" rel="noopener" class="text-sm font-medium bg-white border border-warm-200 px-3 py-1.5 rounded-lg hover:border-brand-300">EMT Madrid</a>
          <a href="https://moovitapp.com/index/es/transporte_p%C3%BAblico-El_Ca%C3%B1averal-Madrid-site_151932634-21" target="_blank" rel="noopener" class="text-sm font-medium bg-white border border-warm-200 px-3 py-1.5 rounded-lg hover:border-brand-300">Moovit</a>
          <a href="https://www.google.com/maps/dir/?api=1&destination=El+Ca%C3%B1averal,+Madrid&travelmode=transit" target="_blank" rel="noopener" class="text-sm font-medium bg-white border border-warm-200 px-3 py-1.5 rounded-lg hover:border-brand-300">Google Maps (cómo llegar)</a>
        </div>
      </div>

      <!-- Mapa con consentimiento -->
      <div class="bg-white rounded-xl border border-warm-200 overflow-hidden mb-10">
        <div class="p-4 border-b border-warm-200">
          <h2 class="font-semibold text-lg">El Cañaveral en el mapa</h2>
        </div>
        <div
          data-maps-embed
          data-src="https://www.google.com/maps?q=El%20Ca%C3%B1averal,%20Madrid&output=embed"
          data-title="Mapa de El Cañaveral"
          class="h-[350px] bg-warm-100 flex flex-col items-center justify-center text-center px-6"
        >
          <p class="text-sm text-gray-500 mb-3">El mapa usa cookies de Google Maps. Púlsalo para cargarlo.</p>
          <button data-maps-load type="button" class="text-sm font-semibold bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors">
            Ver mapa
          </button>
        </div>
      </div>

      <!-- FAQ -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-brand-900 mb-5">Preguntas frecuentes</h2>
        <div class="space-y-3">
          {faq.map((f) => (
            <details class="bg-white rounded-xl border border-warm-200 p-4 group">
              <summary class="font-semibold text-gray-800 cursor-pointer list-none flex items-center justify-between">
                {f.q}
                <span class="text-brand-400 group-open:rotate-180 transition-transform">&#9662;</span>
              </summary>
              <p class="text-gray-600 text-sm mt-3 leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA al directorio -->
      <div class="text-center bg-brand-50 border border-brand-100 rounded-xl p-6">
        <p class="text-brand-900 font-semibold">¿Ya estás en el barrio?</p>
        <p class="text-gray-600 text-sm mt-1 mb-4">Descubre los negocios, restaurantes y servicios de El Cañaveral y alrededores.</p>
        <a href="/directorio" class="inline-block bg-accent-500 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-accent-600 transition-colors">
          Ver el directorio del barrio
        </a>
      </div>

      <p class="text-xs text-gray-400 mt-8">
        Información orientativa elaborada a partir de fuentes oficiales (CRTM, EMT Madrid, Comunidad de Madrid).
        Las líneas, paradas y horarios pueden cambiar; confírmalos en los enlaces oficiales antes de tu viaje.
      </p>
    </div>
  </article>

  <Footer />
</BaseLayout>
